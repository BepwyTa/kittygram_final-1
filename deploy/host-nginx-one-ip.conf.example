# Скопируй на сервер (один VPS с одним публичным IP), например:
#   sudo cp deploy/host-nginx-one-ip.conf.example /etc/nginx/sites-available/kittygram-taski.conf
# Подставь свои домены и порты, затем:
#   sudo ln -s /etc/nginx/sites-available/kittygram-taski.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Сертификаты (бесплатно):
#   sudo apt install -y certbot python3-certbot-nginx
#   sudo certbot --nginx -d kittygram2.ddns.net -d taski2.ddns.net
#
# В панели No-IP: ОБА хоста (A-запись) → один и тот же IP этого VPS.

# --- Kittygram (Docker gateway слушает на хосте порт 9000) ---
server {
    listen 80;
    server_name kittygram2.ddns.net;

    location / {
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://127.0.0.1:9000;
        client_max_body_size 20M;
    }
}

# --- Taski: порт как у тебя на этом сервере (часто 8000 или 8080) ---
server {
    listen 80;
    server_name taski2.ddns.net;

    location / {
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://127.0.0.1:8000;
        client_max_body_size 20M;
    }
}
